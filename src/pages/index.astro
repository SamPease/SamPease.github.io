---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeContent from "../components/HomeContent.astro";

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/project-writeups/", label: "Project Write Ups" }
];

const tocLinks = [
  { href: "/#about", label: "About" },
  { href: "/#research", label: "Research" },
  { href: "/#projects", label: "Projects" },
  { href: "/#teaching", label: "Teaching" },
  { href: "/#interests", label: "Interests" }
];
---

<BaseLayout
  title="Samantha Pease"
  description="Personal site for Samantha Pease with projects, research, and Project Write Ups"
  navLinks={navLinks}
>
  <div class="home-shell">
    <aside class="toc-panel" aria-label="Table of contents">
      <p class="toc-title">On This Page</p>
      <nav>
        <ul>
          {tocLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </aside>

    <div class="home-content">
      <HomeContent />
    </div>
  </div>

  <style>
    .home-shell {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 240px;
      gap: 1rem;
      align-items: start;
    }

    .home-content {
      grid-column: 1;
      grid-row: 1;
    }

    .toc-panel {
      grid-column: 2;
      grid-row: 1;
      align-self: start;
      position: sticky;
      top: 1rem;
      border: 1px solid rgba(29, 56, 87, 0.16);
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.78);
      padding: 0.85rem 0.95rem;
      box-shadow: 0 12px 26px rgba(14, 31, 61, 0.08);
    }

    .toc-title {
      margin: 0 0 0.55rem;
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #0b776e;
    }

    .toc-panel ul {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.34rem;
    }

    .toc-panel a {
      display: block;
      border-radius: 8px;
      padding: 0.28rem 0.42rem;
      color: #1e3f67;
      text-decoration: none;
      font-size: 0.88rem;
      font-weight: 600;
      line-height: 1.32;
    }

    .toc-panel a:hover {
      background: rgba(12, 107, 128, 0.1);
      color: #0b5e73;
    }

    @media (max-width: 980px) {
      .home-shell {
        grid-template-columns: 1fr;
      }

      .home-content,
      .toc-panel {
        grid-column: auto;
        grid-row: auto;
      }

      .toc-panel {
        display: none;
      }
    }
  </style>
</BaseLayout>
