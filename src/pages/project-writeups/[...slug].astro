---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const writeups = await getCollection("blog", ({ data }) => !data.draft);
  return writeups.map((writeup) => ({
    params: { slug: writeup.id.replace(/\.md$/, "") },
    props: { writeup }
  }));
}

const { writeup } = Astro.props;
const { Content, headings } = await render(writeup);
const writeupPath = Astro.url.pathname;

const tocLinks = headings
  .filter((heading) => heading.depth === 2)
  .map((heading) => ({
    href: `${writeupPath}#${heading.slug}`,
    label: heading.text
  }));

---

<BaseLayout title={`${writeup.data.title} | Project Write Ups`} description={writeup.data.description}>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+" crossorigin="anonymous" slot="head" />
  <div class="writeup-shell">
    {
      tocLinks.length > 0 && (
        <aside class="toc-panel" aria-label="Table of contents">
          <p class="toc-title">On This Page</p>
          <nav>
            <ul>
              {tocLinks.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </nav>
        </aside>
      )
    }

    <article class="writeup-article">
      <header class="writeup-header mb-4">
        <p class="eyebrow mb-1">Project Write Up</p>
        <div class="meta-line">
          <span>{writeup.data.date.toLocaleDateString("en-US", { timeZone: "UTC" })}</span>
          <div class="tag-list">
            {writeup.data.tags.map((tag) => <span class="tag-chip">{tag}</span>)}
          </div>
        </div>
      </header>

      <section class="summary-card writeup-body mb-4">
        <Content />
      </section>
    </article>
  </div>

  <style>
    .writeup-shell {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 240px;
      gap: 1rem;
      align-items: start;
    }

    .writeup-article {
      grid-column: 1;
      grid-row: 1;
    }

    .writeup-header {
      padding: 1.15rem 1.2rem;
      border: 1px solid rgba(25, 62, 90, 0.2);
      border-radius: 16px;
      background: linear-gradient(130deg, rgba(248, 255, 250, 0.95), rgba(239, 245, 255, 0.92));
      box-shadow: 0 16px 30px rgba(14, 31, 61, 0.09);
    }

    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.72rem;
      font-weight: 800;
      color: #0b776e;
    }

    .meta-line {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      justify-content: space-between;
      align-items: center;
    }

    .tag-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
    }

    .tag-chip {
      font-size: 0.74rem;
      padding: 0.2rem 0.52rem;
      border-radius: 999px;
      border: 1px solid rgba(12, 107, 128, 0.28);
      background: rgba(12, 107, 128, 0.12);
      color: #0c566a;
    }

    .summary-card {
      border: 1px solid rgba(29, 56, 87, 0.16);
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.78);
      padding: 0.95rem 1.05rem;
    }

    .writeup-body :global(h1) {
      font-size: clamp(1.55rem, 1.1rem + 1.7vw, 2rem);
      line-height: 1.18;
      margin-top: 0.45rem;
      margin-bottom: 0.65rem;
    }

    .writeup-body :global(h2) {
      font-size: clamp(1.22rem, 1rem + 0.95vw, 1.5rem);
      line-height: 1.24;
      margin-top: 1.15rem;
      margin-bottom: 0.48rem;
    }

    .writeup-body :global(h3) {
      font-size: clamp(1.06rem, 0.96rem + 0.55vw, 1.24rem);
      line-height: 1.28;
      margin-top: 0.9rem;
      margin-bottom: 0.34rem;
    }

    .writeup-body :global(h4) {
      font-size: 1rem;
      line-height: 1.3;
      margin-top: 0.75rem;
      margin-bottom: 0.28rem;
    }

    .writeup-body :global(blockquote) {
      margin: 1rem 0;
      padding: 0.7rem 1.1rem;
      border-left: 3px solid var(--accent);
      background: rgba(15, 138, 127, 0.07);
      border-radius: 0 10px 10px 0;
    }

    .writeup-body :global(blockquote p:last-child) {
      margin-bottom: 0;
    }

    .writeup-body :global(img) {
      max-width: 100%;
      height: auto;
      display: block;
    }

    .writeup-body :global(pre) {
      overflow-x: auto;
      max-width: 100%;
    }

    .writeup-body :global(code) {
      word-break: break-word;
    }

    .writeup-body :global(pre code) {
      word-break: normal;
    }

    .writeup-body :global(table) {
      display: block;
      overflow-x: auto;
      max-width: 100%;
      border-collapse: collapse;
      margin: 1rem 0;
      font-size: 0.88rem;
      line-height: 1.5;
    }

    .writeup-body :global(th),
    .writeup-body :global(td) {
      padding: 0.45rem 0.85rem;
      border: 1px solid rgba(29, 56, 87, 0.18);
      text-align: left;
      vertical-align: top;
    }

    .writeup-body :global(th) {
      background: rgba(12, 107, 128, 0.07);
      font-weight: 700;
      color: #0c3f5a;
      white-space: nowrap;
    }

    .writeup-body :global(tr:nth-child(even) td) {
      background: rgba(248, 252, 255, 0.6);
    }

    .writeup-body :global(td:not(:first-child)) {
      text-align: right;
    }

    .toc-panel {
      grid-column: 2;
      grid-row: 1;
      align-self: start;
      position: sticky;
      top: 1rem;
      border: 1px solid rgba(29, 56, 87, 0.16);
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.78);
      padding: 0.85rem 0.95rem;
      box-shadow: 0 12px 26px rgba(14, 31, 61, 0.08);
    }

    .toc-title {
      margin: 0 0 0.55rem;
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #0b776e;
    }

    .toc-panel ul {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.34rem;
    }

    .toc-panel a {
      display: block;
      border-radius: 8px;
      padding: 0.28rem 0.42rem;
      color: #1e3f67;
      text-decoration: none;
      font-size: 0.88rem;
      font-weight: 600;
      line-height: 1.32;
    }

    .toc-panel a:hover {
      background: rgba(12, 107, 128, 0.1);
      color: #0b5e73;
    }

    @media (max-width: 980px) {
      .writeup-shell {
        grid-template-columns: 1fr;
      }

      .writeup-article,
      .toc-panel {
        grid-column: auto;
        grid-row: auto;
      }

      .toc-panel {
        display: none;
      }
    }
  </style>
</BaseLayout>
